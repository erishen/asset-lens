# QQ推送环境变量配置
# 此文件由 setup_qq_push 工具自动生成

# QQ机器人API地址
# go-cqhttp 默认地址: http://localhost:5700/send_private_msg
# 如果机器人在远程服务器，改为: http://服务器IP:5700/send_private_msg
export QQ_PUSH_URL="http://localhost:5700/send_private_msg"

# 接收消息的QQ号
# 多个QQ号用逗号分隔: 123456789,987654321
export QQ_USER_ID="你的QQ号"

# 可选：推送消息格式
# simple: 简洁模式
# detail: 详细模式
export QQ_PUSH_FORMAT="detail"
