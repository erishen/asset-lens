# 数据模式选择
# sample: 使用示例数据（适合演示和测试）
# real: 使用真实数据（私人数据，不会提交到代码仓库）
DATA_MODE=sample

# API Keys (用于获取实时市场数据)
# Finnhub API: https://finnhub.io/dashboard (免费版：60次/分钟，推荐使用)
FINNHUB_API_KEY=your_actual_finnhub_api_key_here
# Alpha Vantage API: https://www.alphavantage.co/support/#api-key (免费版：25次/天，备用)
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# Tushare API: https://tushare.pro/register (免费版：每日10000次，数据完整)
# 用于获取A股历史数据（包含换手率等完整指标）
TUSHARE_TOKEN=your_tushare_token_here

# 数据路径配置
# 示例数据路径
SAMPLE_DATA_PATH=data/sample_data

# 真实数据路径（本地存储，不会被 Git 追踪）
REAL_DATA_PATH=data/real

# 输出路径
OUTPUT_PATH=output

# 缓存路径
CACHE_PATH=cache

# 货币汇率配置
# 默认汇率（如果无法从 API 获取实时汇率）
DEFAULT_USD_RATE=7.1242  # 1 USD = 7.1242 CNY
DEFAULT_HKD_RATE=0.9157  # 1 HKD = 0.9157 CNY

# 分析配置
# 最低收益率阈值（用于警告）
MIN_RETURN_THRESHOLD=2.0

# 定投计算配置
# 工作日占比（定投时按工作日计算）
WORKDAY_RATIO=0.7

# 输出格式
# 支持的格式：console, csv, json, html
OUTPUT_FORMAT=console,csv

# 报告语言
# 支持的语言：zh, en
REPORT_LANGUAGE=zh

# AI 分析配置（可选）
# 支持 LiteLLM 兼容的多种 AI 模型
# API Key（支持以下环境变量，按优先级排序）
# OPENAI_API_KEY=your_openai_api_key_here
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DASHSCOPE_API_KEY=your_dashscope_api_key_here（通义千问）
# ANTHROPIC_API_KEY=your_anthropic_api_key_here（Claude）
# GEMINI_API_KEY=your_gemini_api_key_here（Google）
# AZURE_API_KEY=your_azure_api_key_here（Azure OpenAI）

# AI 模型选择
# 支持的模型别名：
#   - deepseek: DeepSeek Chat
#   - deepseek-reasoner: DeepSeek Reasoner
#   - qwen: 通义千问 Turbo
#   - qwen-plus: 通义千问 Plus
#   - qwen-max: 通义千问 Max
#   - gpt-4: GPT-4
#   - gpt-4-turbo: GPT-4 Turbo
#   - gpt-3.5-turbo: GPT-3.5 Turbo
#   - claude-3: Claude 3 Opus
#   - claude-3-sonnet: Claude 3 Sonnet
#   - claude-3-haiku: Claude 3 Haiku
#   - ollama-llama3: Ollama Llama3（本地）
#   - ollama-qwen: Ollama Qwen2（本地）
# 也可以直接使用完整的模型名称，如：deepseek/deepseek-chat
AI_MODEL=deepseek-chat

# AI 缓存配置
# AI 分析结果缓存有效期（秒），默认 1 小时
AI_CACHE_TTL=3600
